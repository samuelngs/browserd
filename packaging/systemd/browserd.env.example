# Copy to /etc/browserd/browserd.env and set a strong token before starting.
BROWSERD_MCP_HTTP_TOKEN=change-me

# Optional bind settings. Use 0.0.0.0 or :: to listen on all interfaces.
BROWSERD_MCP_HTTP_HOST=127.0.0.1
BROWSERD_MCP_HTTP_PORT=9223

# Local IPC can be enabled with a systemd ExecStart override:
# --mcp-ipc-path=%t/browserd/browserd.sock
