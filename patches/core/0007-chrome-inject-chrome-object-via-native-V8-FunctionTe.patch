+#ifndef HEADLESS_LIB_RENDERER_HEADLESS_CHROME_OBJECT_INJECTOR_H_
+#define HEADLESS_LIB_RENDERER_HEADLESS_CHROME_OBJECT_INJECTOR_H_
+
+#include "content/public/renderer/render_frame_observer.h"
+#include "v8/include/v8-forward.h"
+#include "v8/include/v8-function-callback.h"
+
+namespace headless {
+
+class HeadlessChromeObjectInjector : public content::RenderFrameObserver {
+ public:
+  explicit HeadlessChromeObjectInjector(content::RenderFrame* render_frame);
+  ~HeadlessChromeObjectInjector() override;
+
+  HeadlessChromeObjectInjector(const HeadlessChromeObjectInjector&) = delete;
+  HeadlessChromeObjectInjector& operator=(const HeadlessChromeObjectInjector&) =
+      delete;
+
+  void DidCreateScriptContext(v8::Local<v8::Context> context,
+                              int32_t world_id) override;
+  void OnDestruct() override;
+
+ private:
+  static v8::Local<v8::Function> CreateNativeFunction(
+      v8::Isolate* isolate,
+      v8::Local<v8::Context> context,
+      const char* name,
+      v8::FunctionCallback callback,
+      int length = 0);
+
+  static void GetDetails(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void GetIsInstalled(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void InstallState(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void RunningState(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void RuntimeConnect(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void RuntimeSendMessage(
+      const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void Csi(const v8::FunctionCallbackInfo<v8::Value>& info);
+  static void LoadTimes(const v8::FunctionCallbackInfo<v8::Value>& info);
+};
+
+}  // namespace headless
+
+#endif  // HEADLESS_LIB_RENDERER_HEADLESS_CHROME_OBJECT_INJECTOR_H_
