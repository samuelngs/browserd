From eb5da5343863daa8d86f56ac7b77e4576dc941d4 Mon Sep 17 00:00:00 2001
From: Sam <samuelngs@users.noreply.github.com>
Date: Sun, 10 May 2026 20:25:11 -0600
Subject: [PATCH 08/15] brand: use "Google Chrome" for Sec-CH-UA brand list

Use "Google Chrome" instead of "Chrome" when generating brand version
lists so Sec-CH-UA header matches retail Chrome exactly.

diff --git a/headless/lib/browser/headless_browser_impl.cc b/headless/lib/browser/headless_browser_impl.cc
index aa4bdb593d..2c3a0fc705 100644
--- a/headless/lib/browser/headless_browser_impl.cc
+++ b/headless/lib/browser/headless_browser_impl.cc
@@ -114,12 +114,12 @@ blink::UserAgentMetadata HeadlessBrowser::GetUserAgentMetadata() {
   bool got_seed = base::StringToInt(significant_version, &seed);
   DCHECK(got_seed);
 
-  // Rengenerate the brand version lists with kHeadlessProductName.
+  // Use "Google Chrome" for brand lists to match retail Chrome.
   metadata.brand_version_list = embedder_support::GenerateBrandVersionList(
-      seed, kHeadlessProductName, significant_version,
+      seed, "Google Chrome", significant_version,
       blink::UserAgentBrandVersionType::kMajorVersion);
   metadata.brand_full_version_list = embedder_support::GenerateBrandVersionList(
-      seed, kHeadlessProductName, metadata.full_version,
+      seed, "Google Chrome", metadata.full_version,
       blink::UserAgentBrandVersionType::kFullVersion);
   return metadata;
 }
